# ── Discord ────────────────────────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications → paste its
# token here. Invite the bot to your server with the "Send Messages" +
# "Embed Links" permissions, then paste the guild + channel IDs below.
# (Right-click → Copy ID requires Developer Mode in Discord settings.)
DISCORD_TOKEN=
DISCORD_GUILD_ID=0
DISCORD_USER_ID=0                              # for @mentions on priority posts

# ── Discord channels ───────────────────────────────────────────────────────
# Streams (raw-ish, time-ordered):
DISCORD_FILINGS_CHANNEL_ID=0                   # all SEC filings (with materiality scoring)
DISCORD_INSIDERS_CHANNEL_ID=0                  # Form 4 insider trades
DISCORD_NEWS_CHANNEL_ID=0                      # per-name news + breaking alerts
DISCORD_REDDIT_CHANNEL_ID=0                    # opt-in: notable r/ posts; skips when 0
DISCORD_CRYPTO_CHANNEL_ID=0                    # all per-coin crypto content
DISCORD_MACRO_CHANNEL_ID=0                     # macro/geopolitical news ONLY (fallback: #news)

# Curated (bot's reasoning, lower volume):
DISCORD_PRIORITY_CHANNEL_ID=0                  # material 8-Ks + high-conviction signals
DISCORD_CONVERGENCE_CHANNEL_ID=0               # multi-source agreement (fallback: #priority)
DISCORD_HOT_CHANNEL_ID=0                       # gainers/losers + volume spikes
DISCORD_CALLS_CHANNEL_ID=0                     # call-resolution verdicts
DISCORD_RISK_CHANNEL_ID=0                      # adverse moves on OPEN paper positions
DISCORD_FUNDS_CHANNEL_ID=0                     # autonomous wallet trade narrations
DISCORD_PULSE_CHANNEL_ID=0                     # social-mention spikes only

# Daily / scheduled / system:
DISCORD_DIGEST_CHANNEL_ID=0                    # daily briefing
DISCORD_CATALYSTS_CHANNEL_ID=0                 # forward catalyst calendar (fallback: #digest)
DISCORD_GENERAL_CHANNEL_ID=0                   # lounge: geopolitics↔market musings
DISCORD_META_CHANNEL_ID=0                      # wallet meta / tuning / system messages

# ── LLM: local Ollama (free, needs a GPU box) ──────────────────────────────
# Gemma 4 e4b handles light summarisers (8-K, Form 4, generic).
# Qwen3 30B-A3B (MoE, ~3B active) handles heavy reasoning (10-K/10-Q/13F,
# materiality scoring, daily digest, monthly tuning).
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL_LIGHT=gemma4:e4b
LLM_MODEL_HEAVY=qwen3:30b-a3b

# ── LLM: serverless (OpenAI-compatible) ───────────────────────────────────
# Run both tiers on a hosted provider and Ollama is never touched — so
# the bot runs on a cheap CPU-only VPS or Raspberry Pi (~$25/mo vs ~$300/mo
# to rent a GPU 24/7).
#
# Provider base URLs:
#   OpenRouter → https://openrouter.ai/api/v1     (keys: openrouter.ai/keys)
#   Novita     → https://api.novita.ai/v3/openai  (keys: novita.ai/settings)
#   DeepInfra  → https://api.deepinfra.com/v1/openai
#
# LLM_API_BASE=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-...
# LLM_API_MODEL_LIGHT=meta-llama/llama-3.1-8b-instruct
# LLM_API_MODEL_HEAVY=qwen/qwen3-30b-a3b
#
# OpenRouter-only: pin the upstream provider (+ optional quantization) per
# tier — "provider" or "provider/quant", e.g. deepinfra/fp8, io-net/fp8.
# LLM_API_PROVIDER_LIGHT=deepinfra/fp8
# LLM_API_PROVIDER_HEAVY=gmicloud/fp8
#
# Per-tier overrides — put each tier on a DIFFERENT provider (e.g. free
# light + paid heavy). Overrides win over LLM_API_* for that tier.
# Google AI Studio's free tier is rate-limited; expect occasional 429s.
#   Google AI Studio → https://generativelanguage.googleapis.com/v1beta/openai
# LIGHT_LLM_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
# LIGHT_LLM_API_KEY=...
# LIGHT_LLM_API_MODEL=gemma-3-12b-it
# HEAVY_LLM_API_BASE=https://api.novita.ai/v3/openai
# HEAVY_LLM_API_KEY=...
# HEAVY_LLM_API_MODEL=qwen/qwen3-30b-a3b

# ── Reddit (free, public-RSS, no OAuth) ───────────────────────────────────
REDDIT_USER_AGENT=sentinel/0.1 by <yourname>

# ── SEC (free; the contact email is required per SEC's fair-access rules) ─
EDGAR_USER_AGENT=sentinel/0.1 you@example.com

# ── Cadences (minutes) ────────────────────────────────────────────────────
POLL_FILINGS_MINUTES=10
POLL_REDDIT_MINUTES=15
POLL_HN_MINUTES=30
POLL_PRICES_MINUTES=5
DIGEST_HOUR_ET=16
DIGEST_MINUTE_ET=30

# ── In-process cockpit (NiceGUI dashboard) ────────────────────────────────
# Localhost-only by default (it has a control surface — pause jobs, log
# calls). Set DASHBOARD_HOST=0.0.0.0 to expose on the LAN; for remote
# access use Tailscale, never a raw port-forward.
DASHBOARD_ENABLED=true
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8730
